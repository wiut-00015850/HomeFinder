@model HomeFinder.Models.Reports.ApartmentPriceAnalyticsReportVm
@{
    ViewData["Title"] = "Apartment price analytics";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" />

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h2 class="mb-1">💰 Price analytics</h2>
            <div id="reportPeriod" class="text-muted">
                Average price by district and trend (from @Model.DateFrom.ToString("dd.MM.yyyy") to @Model.DateTo.ToString("dd.MM.yyyy"))
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body d-flex flex-wrap align-items-end gap-2">
            <div>
                <label class="form-label mb-1">From</label>
                <input id="dateFrom" name="dateFrom" type="text" class="form-control form-control-sm"
                       value="@Model.DateFrom.ToString("dd.MM.yyyy")" autocomplete="off" style="width:140px;" />
            </div>
            <div>
                <label class="form-label mb-1">To</label>
                <input id="dateTo" name="dateTo" type="text" class="form-control form-control-sm"
                       value="@Model.DateTo.ToString("dd.MM.yyyy")" autocomplete="off" style="width:140px;" />
            </div>

            <div>
                <label class="form-label mb-1">District</label>
                <select id="districtFilter" class="form-select form-select-sm" style="min-width:180px;">
                    <option value="">All Districts</option>
                    @foreach (var d in Model.Districts)
                    {
                        <option value="@d" selected="@(d == Model.SelectedDistrict)">@d</option>
                    }
                </select>
            </div>

            <div>
                <label class="form-label mb-1">Type (number of rooms)</label>
                <select id="typeFilter" class="form-select form-select-sm" style="min-width:210px;">
                    <option value="all" selected="@(string.IsNullOrWhiteSpace(Model.SelectedApartmentType) || Model.SelectedApartmentType == "all")">All</option>
                    <option value="studio" selected="@(Model.SelectedApartmentType == "studio")">Studio (1)</option>
                    <option value="family" selected="@(Model.SelectedApartmentType == "family")">Family (2-3)</option>
                    <option value="large" selected="@(Model.SelectedApartmentType == "large")">Large (4+)</option>
                </select>
            </div>

            <div>
                <label class="form-label mb-1">Тrend</label>
                <select id="granularityFilter" class="form-select form-select-sm" style="width:160px;">
                    <option value="daily" selected="@(Model.Granularity == "daily")">Daily</option>
                    <option value="weekly" selected="@(Model.Granularity == "weekly")">Weekly</option>
                    <option value="monthly" selected="@(Model.Granularity == "monthly")">Monthly</option>
                </select>
            </div>

            <div class="ms-auto">
                <button id="applyBtn" class="btn btn-primary btn-sm" type="button">Apply</button>
            </div>

            <div id="reportError" class="text-danger small ms-2 d-none"></div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="mb-2">Price trends</h5>
                    <div id="reportData">
                        @await Html.PartialAsync("_ApartmentPriceAnalyticsData", Model)
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Average rent price per district</h5>
                    <div id="reportTable">
                        @await Html.PartialAsync("_ApartmentPriceAnalyticsByDistrictTable", Model)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/ru.js"></script>

    <script>
        let trendChartInstance = null;

        function setError(message) {
            const errorEl = document.getElementById('reportError');
            if (!errorEl) return;
            if (!message) {
                errorEl.classList.add('d-none');
                errorEl.textContent = '';
                return;
            }
            errorEl.textContent = message;
            errorEl.classList.remove('d-none');
        }

        function parseRuDate(value) {
            if (!value) return null;
            const m = value.trim().match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})$/);
            if (!m) return null;
            const day = Number(m[1]);
            const month = Number(m[2]) - 1;
            const year = Number(m[3]);
            const d = new Date(year, month, day);
            if (d.getFullYear() !== year || d.getMonth() !== month || d.getDate() !== day) return null;
            return d;
        }

        function formatRuDate(date) {
            const dd = String(date.getDate()).padStart(2, '0');
            const mm = String(date.getMonth() + 1).padStart(2, '0');
            const yyyy = date.getFullYear();
            return `${dd}.${mm}.${yyyy}`;
        }

        function renderTrendFromJson(jsonText) {
            const canvas = document.getElementById('priceTrendChart');
            if (!canvas || !jsonText) return;

            let payload;
            try {
                payload = JSON.parse(jsonText);
            } catch {
                return;
            }

            const labels = payload.labels || [];
            const avgPrices = payload.avgPrices || [];

            if (trendChartInstance) {
                trendChartInstance.destroy();
                trendChartInstance = null;
            }

            trendChartInstance = new Chart(canvas, {
                type: 'line',
                data: {
                    labels,
                    datasets: [{
                        label: 'Average price',
                        data: avgPrices,
                        borderWidth: 2,
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: true } },
                    scales: { y: { beginAtZero: true } }
                }
            });
        }

        function updatePeriodLabel(fromText, toText) {
            const periodEl = document.getElementById('reportPeriod');
            if (!periodEl) return;
            periodEl.textContent = `Средняя цена и тренд (с ${fromText} по ${toText})`;
        }

        async function reloadReport() {
            setError('');

            const dfEl = document.getElementById('dateFrom');
            const dtEl = document.getElementById('dateTo');
            const districtEl = document.getElementById('districtFilter');
            const typeEl = document.getElementById('typeFilter');
            const granEl = document.getElementById('granularityFilter');

            const fromText = (dfEl?.value || '').trim();
            const toText = (dtEl?.value || '').trim();
            const fromDate = parseRuDate(fromText);
            const toDate = parseRuDate(toText);

            if (!fromDate || !toDate) {
                setError('Введите даты в формате dd.MM.yyyy.');
                return;
            }
            if (fromDate > toDate) {
                setError('Дата "От" не может быть больше даты "До".');
                return;
            }

            const district = (districtEl?.value || '').trim();
            const apartmentType = (typeEl?.value || 'all').trim();
            const granularity = (granEl?.value || 'daily').trim();

            const params = new URLSearchParams();
            params.set('dateFrom', formatRuDate(fromDate));
            params.set('dateTo', formatRuDate(toDate));
            if (district) params.set('district', district);
            if (apartmentType) params.set('apartmentType', apartmentType);
            if (granularity) params.set('granularity', granularity);

            const url = `/Report/ApartmentPriceAnalyticsData?${params.toString()}`;
            const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (!resp.ok) {
                setError('Не удалось загрузить данные отчёта.');
                return;
            }

            const html = await resp.text();
            const temp = document.createElement('div');
            temp.innerHTML = html;

            const chartBlock = temp.querySelector('#chartBlock');
            const jsonBlock = temp.querySelector('#jsonBlock');
            const tableBlock = temp.querySelector('#tableBlock');
            if (!chartBlock || !jsonBlock || !tableBlock) {
                setError('Получен некорректный ответ сервера.');
                return;
            }

            const reportData = document.getElementById('reportData');
            const reportTable = document.getElementById('reportTable');
            if (!reportData || !reportTable) {
                setError('Не удалось обновить данные на странице.');
                return;
            }

            reportData.innerHTML = chartBlock.outerHTML + jsonBlock.outerHTML;
            reportTable.innerHTML = tableBlock.innerHTML;

            updatePeriodLabel(formatRuDate(fromDate), formatRuDate(toDate));
            renderTrendFromJson(document.getElementById('jsonBlock')?.textContent?.trim() || '');
        }

        const applyBtn = document.getElementById('applyBtn');
        if (applyBtn) applyBtn.addEventListener('click', reloadReport);

        flatpickr("#dateFrom", {
            dateFormat: "d.m.Y",
            allowInput: true,
            disableMobile: true
        });

        flatpickr("#dateTo", {
            dateFormat: "d.m.Y",
            allowInput: true,
            disableMobile: true
        });

        renderTrendFromJson(document.getElementById('jsonBlock')?.textContent?.trim() || '');
    </script>
}

