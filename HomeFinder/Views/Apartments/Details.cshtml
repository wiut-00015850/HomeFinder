@model HomeFinder.Models.ApartmentViewModel
@{
    ViewData["Title"] = "Apartment Details";
}

@if (Model.PhotoPaths != null && Model.PhotoPaths.Any())
{
    <div id="photoCarousel" class="carousel slide mb-4" data-bs-ride="carousel" style="border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
        <div class="carousel-inner">
            @{
                int index = 0;
            }
            @foreach (var photo in Model.PhotoPaths)
            {
                <div class="carousel-item @(index == 0 ? "active" : "")" style="background: #f5f5f5;">
                    <img src="@photo"
                         class="d-block w-100"
                         alt="Photo"
                         style="height: 450px; object-fit: contain; padding: 20px; background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);"
                         loading="lazy">
                </div>
                index++;
            }
        </div>

        @if (Model.PhotoPaths.Count > 1)
        {
            <button class="carousel-control-prev" type="button" data-bs-target="#photoCarousel" data-bs-slide="prev" style="background: rgba(0,0,0,0.3); border-radius: 50%; width: 50px; height: 50px; left: 20px;">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#photoCarousel" data-bs-slide="next" style="background: rgba(0,0,0,0.3); border-radius: 50%; width: 50px; height: 50px; right: 20px;">
                <span class="carousel-control-next-icon"></span>
            </button>
        }

        @* Индикаторы фото *@
        @if (Model.PhotoPaths.Count > 1)
        {
            <div class="carousel-indicators" style="bottom: 10px;">
                @for (int i = 0; i < Model.PhotoPaths.Count; i++)
                {
                    <button type="button"
                            data-bs-target="#photoCarousel"
                            data-bs-slide-to="@i"
                            class="@(i == 0 ? "active" : "")"
                            style="background-color: rgba(255,255,255,0.7); width: 12px; height: 12px; border-radius: 50%; margin: 0 5px;">
                    </button>
                }
            </div>
        }
    </div>
}
else
{
    <div class="bg-light text-center p-5 mb-4" style="border-radius: 12px; border: 2px dashed #ccc; min-height: 300px; display: flex; align-items: center; justify-content: center;">
        <div>
            <p style="font-size: 48px; margin-bottom: 10px;">🖼️</p>
            <p class="text-muted">No photos available</p>
        </div>
    </div>
}

<style>
    .carousel-item img {
        transition: transform 0.3s ease-in-out;
    }

        .carousel-item img:hover {
            transform: scale(1.02);
        }

    .carousel-control-prev,
    .carousel-control-next {
        transition: all 0.3s ease;
    }

        .carousel-control-prev:hover,
        .carousel-control-next:hover {
            background: rgba(0,0,0,0.5) !important;
        }
</style>


        <!-- INFORMATION -->
        <div class="col-md-6">
            <h2>@Model.StreetAddress, @Model.BuildingNumber</h2>
            <p class="text-muted">@Model.District, @Model.City</p>

            <div class="card mb-4">
                <div class="card-body">
                    <h4>
                        <span class="badge bg-success" style="font-size: 1.5rem;">@Model.Price.ToString("F0") UZS</span>
                        <span class="badge bg-secondary">per month</span>
                    </h4>

                    <hr>

                    <div class="row text-center">
                        <div class="col-4">
                            <h5>📐 Size</h5>
                            <p class="lead">@Model.Size m²</p>
                        </div>
                        <div class="col-4">
                            <h5>🚪 Rooms</h5>
                            <p class="lead">@Model.Rooms</p>
                        </div>
                        <div class="col-4">
                            <h5>⭐️ Rating</h5>
                            <p class="lead">@(Model.ReviewCount > 0 ? Model.AverageRating.ToString("F1") : "—")</p>
                        </div>
                        <div class="col-4">
                            <h5>👁️ Views</h5>
                            <p class="lead">@Model.Views</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">📝 Description</div>
                <div class="card-body">
                    @Model.Description
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">👤 Owner</div>
                <div class="card-body">
                    <p><strong>@Model.LandlordName</strong></p>
                    <p><a href="tel:@Model.PhoneNumber">@Model.PhoneNumber</a></p>
                </div>
            </div>

            @if (Context.Session.GetString("UserRole") == "Tenant")
            {
                <div class="card mb-4">
                    <div class="card-header">💬 Actions</div>
                    <div class="card-body">
                        <a href="tel:@Model.PhoneNumber" class="btn btn-warning w-100 mb-2">
                            📞 Call
                        </a>
                        <a href="@Url.Action("Schedule", "Appointments", new { apartmentId = Model.ApartmentId })" class="btn btn-success w-100 mb-2">
                            📅 Book Appointment
                        </a>
                        <form asp-controller="Favorites" asp-action="AddToFavorites" method="post" class="d-inline w-100" id="favoriteForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="apartmentId" value="@Model.ApartmentId" />
                            <button type="button" class="btn btn-outline-danger w-100" id="favBtn" onclick="toggleFavorite(event)">
                                <span id="favIcon">❤️</span> <span id="favText">Add to Favorites</span>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- REVIEW FORM -->
                <div class="card mb-4">
                    <div class="card-header">✍️ Leave a Review</div>
                    <div class="card-body">
                        <form asp-controller="Reviews" asp-action="AddReview" method="post" id="reviewForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="apartmentId" value="@Model.ApartmentId" />

                            <div class="mb-3">
                                <label class="form-label">⭐️ Rating</label>
                                <select name="rating" class="form-control" required>
                                    <option value="">-- Select --</option>
                                    <option value="5">⭐️⭐️⭐️⭐️⭐️ Excellent</option>
                                    <option value="4">⭐️⭐️⭐️⭐️ Good</option>
                                    <option value="3">⭐️⭐️⭐️ Average</option>
                                    <option value="2">⭐️⭐️ Poor</option>
                                    <option value="1">⭐️ Very Poor</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">💭 Comment</label>
                                <textarea name="comment" class="form-control" rows="4" placeholder="Share your opinion..."></textarea>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">📤 Submit Review</button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <a href="@Url.Action("Login", "Account")">Sign in as a tenant</a> to leave a review
                </div>
            }
        </div>
    </div>

</div>

<!-- ⭐️ REVIEWS - FULLY SEPARATED WITHOUT FOOTER -->
@if (Model != null && Model.ReviewCount > 0)
{
    <div class="container mt-5 mb-5">
        <h3>💬 Reviews (@Model.ReviewCount)</h3>
        @if (Model.ReviewCount > Model.Reviews.Count)
        {
            <p class="text-muted small mb-0">Showing @Model.Reviews.Count most recent of @Model.ReviewCount reviews.</p>
        }

        <div id="reviewSummaryCard" class="card border-0 shadow-sm mt-4 mb-4" style="background: linear-gradient(135deg, #f7fbff 0%, #eef4ff 100%); border-radius: 18px;">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                    <h5 class="mb-0">🧠 Review Summary</h5>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <button type="button" class="btn btn-sm btn-outline-primary" id="reviewSummaryRefreshBtn" title="Request new summary">
                            Update summary
                        </button>
                        <span class="badge rounded-pill bg-primary-subtle text-primary-emphasis" style="font-size: 0.85rem;">
                            @Model.ReviewCount reviews analyzed
                        </span>
                    </div>
                </div>

                <div id="reviewSummaryLoading" class="text-muted">
                    Generating summary...
                </div>

                <div id="reviewSummaryError" class="alert alert-light border d-none mb-0"></div>

                <div id="reviewSummaryContent" class="d-none">
                    <p id="reviewSummaryOverview" class="mb-2"></p>
                    <p id="reviewSummaryTrend" class="text-muted mb-3 d-none"></p>

                    <div id="reviewSummaryPositivesWrap" class="mb-3 d-none">
                        <div class="fw-semibold text-success mb-2">Most mentioned positives</div>
                        <div id="reviewSummaryPositives" class="d-flex flex-wrap gap-2"></div>
                    </div>

                    <div id="reviewSummaryNegativesWrap" class="mb-3 d-none">
                        <div class="fw-semibold text-warning mb-2">Things to watch</div>
                        <div id="reviewSummaryNegatives" class="d-flex flex-wrap gap-2"></div>
                    </div>

                    <div id="reviewSummaryBreakdown" class="small text-muted d-none"></div>
                    <div id="reviewSummaryMeta" class="small text-muted mt-2"></div>
                </div>
            </div>
        </div>

        @if (Model.Reviews != null && Model.Reviews.Count > 0)
        {
            <div class="row mt-4">
                @foreach (var review in Model.Reviews)
                {
                    <div class="col-md-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h6 class="card-title mb-0">@(review.User?.FirstName ?? "Anonymous")</h6>
                                    <small class="text-muted">
                                        @if (review.CreatedAt.HasValue)
                                        {
                                            @review.CreatedAt.Value.ToString("dd.MM.yyyy")
                                        }
                                    </small>
                                </div>
                                <div class="mb-3">
                                    @for (int i = 0; i < (review.Rating ?? 0); i++)
                                    {
                                        <span class="text-warning">⭐️</span>
                                    }
                                </div>
                                <p class="card-text">@review.Comment</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}
else
{
    <div class="container mt-5 mb-5">
        <h3>💬 Reviews (0)</h3>
        <div class="alert alert-info">
            📭 No reviews yet. Be the first!
        </div>
    </div>
}

<!-- Extra spacing for footer -->
<div style="height: 150px;"></div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
    const hasReviews = @((Model.ReviewCount > 0).ToString().ToLowerInvariant());
    const reviewSummaryBaseUrl = '@(Url.Action("GetReviewSummary", "Apartments", new { id = Model.ApartmentId }) ?? "")';

    function reviewSummaryUrl(forceRefresh) {
        if (!forceRefresh) return reviewSummaryBaseUrl;
        const sep = reviewSummaryBaseUrl.indexOf('?') >= 0 ? '&' : '?';
        return reviewSummaryBaseUrl + sep + 'refresh=true';
    }

    function setReviewSummaryBusy(busy) {
        const btn = document.getElementById('reviewSummaryRefreshBtn');
        if (btn) btn.disabled = !!busy;
    }

    /** Детали ошибки с сервера — смотрите в F12 → Console (и вкладка Network → ответ GetReviewSummary). */
    function logReviewSummaryResponse(data) {
        if (data && data.diagnostic) {
            console.warn('[HomeFinder] Summary — diagnostic:', data.diagnostic);
        }
        if (data && (data.status === 'disabled' || data.status === 'no_data' || data.diagnostic)) {
            console.info('[HomeFinder] Summary — полный ответ API:', data);
        }
    }

    function renderBadgeList(containerId, wrapId, items, badgeClass) {
        const wrap = document.getElementById(wrapId);
        const container = document.getElementById(containerId);
        if (!wrap || !container) return;

        container.innerHTML = '';
        if (!items || items.length === 0) {
            wrap.classList.add('d-none');
            return;
        }

        items.forEach(item => {
            const span = document.createElement('span');
            span.className = `badge rounded-pill ${badgeClass}`;
            span.textContent = item;
            container.appendChild(span);
        });

        wrap.classList.remove('d-none');
    }

    function renderReviewSummary(summary, generatedAtUtc, message) {
        const loading = document.getElementById('reviewSummaryLoading');
        const error = document.getElementById('reviewSummaryError');
        const content = document.getElementById('reviewSummaryContent');
        const overview = document.getElementById('reviewSummaryOverview');
        const trend = document.getElementById('reviewSummaryTrend');
        const breakdown = document.getElementById('reviewSummaryBreakdown');
        const meta = document.getElementById('reviewSummaryMeta');

        if (!summary || !content || !overview || !trend || !breakdown || !meta) return;

        if (loading) loading.classList.add('d-none');
        if (error) error.classList.add('d-none');
        content.classList.remove('d-none');

        overview.textContent = summary.overview || '';

        if (summary.recentTrend) {
            trend.textContent = summary.recentTrend;
            trend.classList.remove('d-none');
        } else {
            trend.textContent = '';
            trend.classList.add('d-none');
        }

        if (summary.ratingBreakdown) {
            breakdown.textContent = summary.ratingBreakdown;
            breakdown.classList.remove('d-none');
        } else {
            breakdown.textContent = '';
            breakdown.classList.add('d-none');
        }

        renderBadgeList('reviewSummaryPositives', 'reviewSummaryPositivesWrap', summary.positiveHighlights, 'text-bg-success');
        renderBadgeList('reviewSummaryNegatives', 'reviewSummaryNegativesWrap', summary.negativeHighlights, 'text-bg-warning');

        if (generatedAtUtc) {
            const dt = new Date(generatedAtUtc);
            const text = Number.isNaN(dt.getTime())
                ? (message || '')
                : `Updated: ${dt.toLocaleString()}${message ? ` • ${message}` : ''}`;
            meta.textContent = text;
        } else {
            meta.textContent = message || '';
        }
    }

    function showReviewSummaryMessage(message) {
        const loading = document.getElementById('reviewSummaryLoading');
        const error = document.getElementById('reviewSummaryError');
        const content = document.getElementById('reviewSummaryContent');

        if (loading) loading.classList.add('d-none');
        if (content) content.classList.add('d-none');
        if (error) {
            error.textContent = message;
            error.classList.remove('d-none');
        }
        setReviewSummaryBusy(false);
    }

    async function loadReviewSummary(forceRefresh) {
        if (!hasReviews) return;

        setReviewSummaryBusy(true);

        const loading = document.getElementById('reviewSummaryLoading');
        const err = document.getElementById('reviewSummaryError');
        const content = document.getElementById('reviewSummaryContent');

        if (forceRefresh) {
            if (content) content.classList.add('d-none');
            if (err) err.classList.add('d-none');
        }

        if (loading) {
            loading.classList.remove('d-none');
            loading.textContent = forceRefresh
                ? 'Updating summary ... Normally 1-3 minutes.'
                : 'Generating summary... Can take several minutes.';
        }

        try {
            const controller = new AbortController();
            const timeoutId = window.setTimeout(() => controller.abort(), 200000);

            const response = await fetch(reviewSummaryUrl(!!forceRefresh), {
                signal: controller.signal
            });
            window.clearTimeout(timeoutId);

            if (!response.ok) {
                const errBody = await response.text().catch(function() { return ''; });
                console.error('[HomeFinder] GetReviewSummary HTTP', response.status, response.statusText, errBody ? errBody.slice(0, 800) : '');
                throw new Error('Failed to load review summary');
            }

            const data = await response.json();
            logReviewSummaryResponse(data);

            if (data.status === 'ready' && data.summary) {
                renderReviewSummary(data.summary, data.generatedAtUtc, data.message || '');
                return;
            }

            if (data.status === 'disabled' || data.status === 'no_data') {
                showReviewSummaryMessage(data.message || 'Summary is unavailable now.');
                return;
            }

            if (data.summary) {
                renderReviewSummary(data.summary, data.generatedAtUtc, data.message || '');
                return;
            }

            showReviewSummaryMessage(data.message || 'Summary is unavailable now.');
        } catch (error) {
            console.error('[HomeFinder] Саммари — ошибка fetch (сеть / CORS / таймаут):', error);
            showReviewSummaryMessage('Не удалось получить ответ (сеть или таймаут). Press "Update summary" again.');
        } finally {
            setReviewSummaryBusy(false);
        }
    }

    const refreshSummaryBtn = document.getElementById('reviewSummaryRefreshBtn');
    if (refreshSummaryBtn) {
        refreshSummaryBtn.addEventListener('click', function() {
            loadReviewSummary(true);
        });
    }

    const scheduleSummary = window.requestIdleCallback
        ? (cb) => window.requestIdleCallback(cb, { timeout: 1200 })
        : (cb) => window.setTimeout(cb, 400);

    scheduleSummary(() => { loadReviewSummary(false); });

    @if (Context.Session.GetString("UserRole") == "Tenant")
    {
        <text>
                    // ✅ Check favorite status on load
                    checkFavoriteStatus();

                    async function checkFavoriteStatus() {
                        try {
                            const response = await fetch('@Url.Action("IsFavorited", "Favorites")' + '?apartmentId=@Model.ApartmentId');
                            const data = await response.json();

                            if (data.favorited) {
                                setFavorited(true);
                            } else {
                                setFavorited(false);
                            }
                        } catch (error) {
                            console.error('Error checking favorite status:', error);
                        }
                    }

                    function setFavorited(isFavorited) {
                        const btn = document.getElementById('favBtn');
                        const icon = document.getElementById('favIcon');
                        const text = document.getElementById('favText');

                        if (isFavorited) {
                            icon.textContent = '💔';
                            text.textContent = 'Remove from Favorites';
                            btn.classList.remove('btn-outline-danger');
                            btn.classList.add('btn-danger');
                        } else {
                            icon.textContent = '❤️';
                            text.textContent = 'Add to Favorites';
                            btn.classList.remove('btn-danger');
                            btn.classList.add('btn-outline-danger');
                        }
                    }

                    function toggleFavorite(event) {
                        event.preventDefault();
                        document.getElementById('favoriteForm').submit();
                    }
        </text>
    }
    });
</script>
